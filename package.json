{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "lint": "eslint resources/js --fix",
        "format": "prettier --write \"resources/**/*.{js,css,blade.php}\"",
        "lint:check": "eslint resources/js",
        "format:check": "prettier --check \"resources/**/*.{js,css,blade.php}\"",
        "prepare": "husky"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.0",
        "@tailwindcss/vite": "^4.0.0",
        "@typescript-eslint/eslint-plugin": "^8.55.0",
        "@typescript-eslint/parser": "^8.55.0",
        "alpinejs": "^3.15.8",
        "autoprefixer": "^10.4.24",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "eslint": "^9.39.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-vue": "^10.7.0",
        "husky": "^9.1.7",
        "laravel-vite-plugin": "^2.0.0",
        "lint-staged": "^16.2.7",
        "postcss": "^8.5.6",
        "prettier": "^3.8.1",
        "tailwindcss": "^4.1.18",
        "vite": "^7.0.7"
    },
    "lint-staged": {
        "resources/js/**/*.js": [
            "eslint --fix",
            "prettier --write"
        ],
        "resources/css/**/*.css": [
            "prettier --write"
        ],
        "resources/views/**/*.blade.php": [
            "prettier --write"
        ],
        "app/**/*.php": [
            "./vendor/bin/php-cs-fixer fix"
        ]
    }
}
